<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradiente"
    android:fitsSystemWindows="true">

    <!-- ── TopBar ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CCFFFFFF"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_store"
            app:navigationIconTint="@color/acento_azul"
            app:title="@string/title_ruta"
            app:titleTextColor="@color/texto_primario"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:subtitleTextColor="@color/texto_secundario"
            app:subtitleTextAppearance="@style/TextAppearance.Material3.BodySmall"
            app:menu="@menu/toolbar_actions"/>

        <!-- Aviso para el reponedor -->
        <TextView
            android:id="@+id/tvAvisoBusqueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/aviso_busqueda"
            android:textColor="@color/acento_verde"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp"
            android:visibility="gone"/>

        <!-- Search / Rutero Selector -->
        <LinearLayout
            android:id="@+id/layoutSearchRutero"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_liquid_glass"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/tvSearchIcono"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"
                android:tint="@color/texto_secundario"
                android:contentDescription="Buscar ruta"/>

            <AutoCompleteTextView
                android:id="@+id/searchRutero"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Busca tu ruta aquí"
                android:textColorHint="@color/texto_secundario"
                android:textColor="@color/texto_primario"
                android:textSize="15sp"
                android:textStyle="bold"
                android:inputType="text"
                android:gravity="center_vertical"
                android:background="@android:color/transparent"
                android:padding="0dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▾"
                android:textSize="20sp"
                android:textColor="@color/texto_secundario"
                android:contentDescription="Abrir lista de rutas"/>
        </LinearLayout>

        <!-- Rutas recientes -->
        <LinearLayout
            android:id="@+id/layoutRecentRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recientes"
                android:textColor="@color/texto_secundario"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:id="@+id/recentRoutesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"/>
        </LinearLayout>

        <!-- Summary Bar -->
        <LinearLayout
            android:id="@+id/layoutSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="2dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="4dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_store"
                android:tint="@color/texto_secundario"
                android:importantForAccessibility="no"
                android:layout_marginEnd="3dp"/>
            <TextView
                android:id="@+id/tvStatsLocales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 locales"
                android:textColor="@color/texto_secundario"
                android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_label"
                    android:tint="@color/texto_secundario"
                    android:importantForAccessibility="no"
                    android:layout_marginEnd="3dp"/>
                <TextView
                    android:id="@+id/tvStatsMarcas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 marcas"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_visits"
                    android:tint="@color/texto_secundario"
                    android:importantForAccessibility="no"
                    android:layout_marginEnd="3dp"/>
                <TextView
                    android:id="@+id/tvStatsVisitas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 visitas"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Offline banner -->
        <LinearLayout
            android:id="@+id/layoutOffline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="4dp"
            android:background="#CCE65100"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_wifi_off"
                android:tint="@android:color/white"
                android:contentDescription="Sin conexión"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvOffline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sin_conexion"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Day Selector -->
        <HorizontalScrollView
            android:id="@+id/layoutDaySelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/dayChipsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:background="@drawable/bg_liquid_glass"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp"
                app:chipSpacingHorizontal="4dp"
                app:singleSelection="true"
                app:selectionRequired="false"/>
        </HorizontalScrollView>

        <Button
            android:id="@+id/btnReintentar"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target_min"
            android:minWidth="@dimen/touch_target_min"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="@string/reiniciar_carga"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/acento_azul"
            android:textSize="12sp"
            android:visibility="gone"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/containerPrincipal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── Contenido de Rutero ── -->
        <LinearLayout
            android:id="@+id/layoutRuteroContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>

        <!-- ── Panel de inicio ── -->
        <LinearLayout
            android:id="@+id/panelInicio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                app:indicatorColor="@color/acento_azul"
                app:trackColor="@color/blanco_glass"
                app:trackThickness="4dp"/>

            <TextView
                android:layout_marginTop="24dp"
                android:text="@string/preparando_ruta"
                android:textSize="18sp"
                android:textColor="@color/texto_primario"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_marginTop="6dp"
                android:text="@string/espera_momento"
                android:textSize="14sp"
                android:textColor="@color/texto_secundario"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ── Panel de cargando ── -->
        <LinearLayout
            android:id="@+id/panelCargando"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="48dp"
            android:visibility="gone"
            android:background="#FFF0F2F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvCargandoTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sincronizando"
                    android:textColor="@color/texto_primario"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    app:indicatorColor="@color/acento_azul"
                    app:trackColor="@color/blanco_glass"
                    app:trackThickness="6dp"
                    app:trackCornerRadius="4dp"/>

                <TextView
                    android:id="@+id/tvCargandoMensaje"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/iniciando"
                    android:textColor="@color/texto_secundario"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
