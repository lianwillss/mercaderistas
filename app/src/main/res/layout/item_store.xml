<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/card_glass"
    app:strokeColor="@color/blanco_glass_borde"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Store Name + Code + Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLocalNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOMBRE LOCAL"
                    android:textColor="@color/texto_primario"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="2"/>

                <TextView
                    android:id="@+id/tvLocalCodigo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Código"
                    android:textColor="@color/texto_secundario"
                    android:textSize="11sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvCantidadMarcas"
                android:layout_width="@dimen/touch_target_min"
                android:layout_height="@dimen/touch_target_min"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/texto_blanco"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_prioridad"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Cantidad de marcas"/>
        </LinearLayout>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textColor="@color/texto_secundario"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@android:drawable/ic_menu_mylocation"
                android:drawablePadding="8dp"
                android:drawableTint="@color/texto_secundario"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Brands Container -->
        <LinearLayout
            android:id="@+id/layoutClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@null"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
