<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradiente"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#F0FFFFFF"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvPageInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/texto_primario"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnCerrar"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_target_min"
            android:minWidth="@dimen/touch_target_min"
            android:gravity="center"
            android:text="@string/cerrar"
            android:textColor="@color/acento_azul"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="0dp"
            android:background="@drawable/bg_glass_button"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"/>

        <LinearLayout
            android:id="@+id/layoutPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="28dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_page_indicator"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/ivSwipeArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_up"
                android:contentDescription="Deslizar hacia arriba"
                android:layout_marginEnd="8dp"
                android:tint="@color/texto_secundario"/>

            <TextView
                android:id="@+id/tvPageInfoBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_primario"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="1 de 3"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
